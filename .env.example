# ===========================================
# Kyo-Blog Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.

# --- Notion CMS (required for blog) ---
NOTION_ACCESS_TOKEN=secret_xxx
NOTION_BLOG_DATABASE_ID=xxx-xxx-xxx

# --- Site URL (optional, defaults to https://kyo-sai-blog.netlify.app) ---
NEXT_PUBLIC_SITE_URL=https://kyo-sai-blog.netlify.app

# --- EmailJS (required for contact form) ---
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxx

# --- Calendly (optional, for agenda page booking widget) ---
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username

# --- Google Analytics (optional) ---
GOOGLE_ANALYTICS_TRACKING_ID=G-XXXXXXX
